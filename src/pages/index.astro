---
import { getCollection } from 'astro:content';
import AppLayout from '../layouts/AppLayout.astro';
import {
  sortByDateDesc,
  summarizeMarkdown,
  formatDateLabel,
  toTagString,
  isComplete,
} from '../lib/content-utils';

const posts = sortByDateDesc((await getCollection('posts')).filter(isComplete)).slice(0, 3);
const projects = (await getCollection('projects')).filter(isComplete);
---

<AppLayout
  title="Daniel Agbemava — Software Engineer"
  description="Software engineer focused on backend and mobile systems. Building things that matter."
>
  <!-- ── Hero ──────────────────────────────── -->
  <section class="landing-hero">
    <canvas id="hero-canvas" class="landing-hero-canvas"></canvas>
    <div class="landing-hero-shade"></div>
    <div class="landing-hero-copy anim-fade-in">
      <p class="kicker">Systems Architect • Backend & Mobile Engineer</p>
      <h1>
        <span class="hero-word">Hi, I'm </span>
        <span class="hero-word hero-word--accent">Daniel.</span>
      </h1>
      <p>
        I build reliable backend systems and polished mobile experiences.
        Currently working on open-source engineering initiatives and crafting
        software that bridges complex architecture with delightful user
        experiences.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/projects/">
          <span class="btn-icon">◈</span> View Projects
        </a>
        <a class="btn btn-secondary" href="/posts/">
          <span class="btn-icon">▤</span> Read Posts
        </a>
      </div>
    </div>
  </section>

  <!-- ── Latest Posts ─────────────────────── -->
  <section class="section-preview">
    <div class="section-preview-header">
      <h2>Latest Posts</h2>
      <a class="section-preview-link" href="/posts/">View all →</a>
    </div>
    <div class="preview-grid">
      {
        posts.map((post) => (
          <a class="preview-card holo-panel" href={`/posts/${post.slug}/`}>
            <span class="preview-card-meta">
              {formatDateLabel(post.data.date)} •{' '}
              {toTagString(post.data.categories) || 'Post'}
            </span>
            <h3>{post.data.title}</h3>
            <p>{summarizeMarkdown(post.body || '', 140)}</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ── Projects ─────────────────────────── -->
  <section class="section-preview">
    <div class="section-preview-header">
      <h2>Projects</h2>
      <a class="section-preview-link" href="/projects/">View all →</a>
    </div>
    <div class="preview-grid">
      {
        projects.map((proj) => (
          <a class="preview-card holo-panel" href={`/projects/${proj.slug}/`}>
            <span class="preview-card-meta">
              {toTagString(proj.data.stack) || 'Project'}
            </span>
            <h3>{proj.data.title}</h3>
            <p>{summarizeMarkdown(proj.body || '', 140)}</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ── Scripts ──────────────────────────── -->
  <script>
    import { initHeroScene } from '../scripts/hero-scene.js';
    import { initSnitch } from '../scripts/sprite.js';
    initHeroScene();
    initSnitch();
  </script>
</AppLayout>
