---
import { getCollection } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';
import { toTagString, summarizeMarkdown, isComplete } from '../../lib/content-utils';

const projects = (await getCollection('projects')).filter(isComplete);
---

<AppLayout
  title="Projects | Willows Bell"
  description="Portfolio of software projects and systems."
>
  <section class="listing-page">
    <header class="listing-header anim-fade-in">
      <div class="status-indicator">
        <span class="status-dot"></span>
        <span>DOSSIER // ALL_PROJECTS</span>
      </div>
      <h1>Projects</h1>
      <p class="listing-subtitle">Systems, apps, and tools I've built.</p>
    </header>

    <div class="listing-grid listing-grid--2col anim-slide-up">
      {
        projects.map((proj) => (
          <a class="listing-card holo-panel" href={`/projects/${proj.slug}/`}>
            <div class="listing-card-header">
              <span class="listing-card-tag">
                {toTagString(proj.data.stack) || 'Project'}
              </span>
            </div>
            <h2>{proj.data.title}</h2>
            <p>{summarizeMarkdown(proj.body || '', 180)}</p>
            {proj.data.tech && proj.data.tech.length > 0 && (
              <div class="listing-tech-row">
                {proj.data.tech.slice(0, 4).map((t) => (
                  <span class="listing-tech-badge">{t.name}</span>
                ))}
              </div>
            )}
          </a>
        ))
      }
    </div>
  </section>
</AppLayout>
