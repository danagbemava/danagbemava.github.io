---
import { getCollection } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
    const experiments = await getCollection('experiments');
    return experiments.map((entry) => ({
        params: { slug: entry.slug },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const scriptPath = `/experiments/${entry.data.script}`;

// Read source code at build time for the code preview
const publicDir = path.resolve(process.cwd(), 'public');
const sourceFile = path.join(publicDir, 'experiments', entry.data.script);
let sourceCode = '';
try {
    sourceCode = fs.readFileSync(sourceFile, 'utf-8');
} catch {
    sourceCode = '// Source file not found';
}
---

<AppLayout
    title={`${entry.data.title} | Experiment`}
    description={entry.data.description || 'An interactive experiment.'}
>
    <section class="entry-page experiment-page">
        <article class="entry-shell experiment-detail anim-fade-in">
            <header class="entry-header-bar">
                <div class="status-indicator">
                    <span class="status-dot"></span>
                    <span>LABORATORY // EXPERIMENT_ACTIVE</span>
                </div>
                <div>MODULE: {entry.slug.toUpperCase().replace(/-/g, '_')}</div>
            </header>

            <div class="anim-slide-up">
                <h1>{entry.data.title}</h1>
                {
                    entry.data.description && (
                        <p class="experiment-desc">{entry.data.description}</p>
                    )
                }
            </div>

            <div class="experiment-tab-bar anim-slide-up anim-delay-1">
                <button class="experiment-tab active" data-tab="preview"
                    >▶ Live Preview</button
                >
                <button class="experiment-tab" data-tab="code"
                    >{} Source Code</button
                >
            </div>

            <div
                class="experiment-panel experiment-preview-panel anim-slide-up anim-delay-2"
                id="panel-preview"
            >
                <div class="experiment-preview">
                    <iframe
                        src={scriptPath}
                        title={`${entry.data.title} preview`}
                        sandbox="allow-scripts allow-same-origin"
                        loading="lazy"></iframe>
                </div>
            </div>

            <div
                class="experiment-panel experiment-code-panel"
                id="panel-code"
                hidden
            >
                <div class="experiment-code">
                    <pre><code>{sourceCode}</code></pre>
                </div>
            </div>
        </article>
    </section>

    <script>
        const tabs = document.querySelectorAll('.experiment-tab');
        const panels = document.querySelectorAll('.experiment-panel');

        tabs.forEach((tab) => {
            tab.addEventListener('click', () => {
                const target = tab.getAttribute('data-tab');
                tabs.forEach((t) => t.classList.remove('active'));
                tab.classList.add('active');
                panels.forEach((p) => {
                    if (p.id === `panel-${target}`) {
                        p.hidden = false;
                    } else {
                        p.hidden = true;
                    }
                });
            });
        });
    </script>
</AppLayout>
